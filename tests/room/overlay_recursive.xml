<fireboxroom>
  <assets>
  </assets>
  <room use_local_asset="room_plane" fwd="0 0 -1">
    
    <!-- recursive (discovery-map game-style) overlay room                -->
    <!--                                                                  -->
    <!-- important: 1. use url_pos to offset the scene,                   -->
    <!--               that way the overlay-rooms align correctly         -->
    <!--            2. once you set a js_id="foo" on an object            -->
    <!--               it will not duplicate, but move to the nested room -->
    <!--            3. <link auto_load="true"...> will auto-load the      -->
    <!--               nested room                                        -->

    <object collision_id="room1_collision" shadows="true" id="room3" pos="0 -4.68 0"/>

    <text text="this room was just opened" pos="0 5 -15" js_id="unique" col="0 0 0" scale="20 20 20" billboard="true"/>

    <link url="#" url_pos="0 0 -30" pos="0 0.01 -21.72" scale="2 3 1" collision_scale="1 1 0.05" shader_id="defaultportal" size="1 1 1">
      <object scale="20 21 1" id="plane" opacity="0.5" pos="0 0 -0.5" lighting="false"/>
    </link>
    
    <link url="#" auto_load="true" url_pos="0 0 -30" pos="-21.72 0.01 0" rotation="0 90 0" scale="2 3 1" collision_scale="1 1 0.05" shader_id="defaultportal" size="1 1 1">
      <object scale="20 21 1" id="plane" opacity="0.3" pos="0 0 -0.5" lighting="false"/>
    </link>

  </room>
</fireboxroom>
