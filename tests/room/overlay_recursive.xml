<fireboxroom>
  <assets>
  </assets>
  <room use_local_asset="room_plane" fwd="0 0 -1">

    <!-- room environment                                      -->
    <!-- important: use pos to offset the scene,               -->
    <!--            that way the overlay-rooms align correctly -->
    <object pos="0 0 -30">   

      <object collision_id="room1_collision" shadows="true" id="room3" pos="0 -4.68 0"/>

      <!-- example portals                                  -->
      <!-- recursive (discovery-map style) overlay room    -->
      <link overlay="true" pos="0 0.01 -21.72" scale="2 3 1" collision_scale="1 1 0.05" url="#" shader_id="defaultportal" size="1 1 1">
        <object scale="20 21 1" sync="true" id="plane" opacity="0.5" pos="0 0 -0.5" lighting="false"/>
      </link>
      
      <link overlay="true" pos="-21.72 0.01 0" rotation="0 90 0" scale="2 3 1" collision_scale="1 1 0.05" url="#" shader_id="defaultportal" size="1 1 1">
        <object scale="20 21 1" sync="true" id="plane" opacity="0.3" pos="0 0 -0.5" lighting="false"/>
      </link>

    </object>
    
  </room>
</fireboxroom>
