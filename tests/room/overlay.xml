<fireboxroom>
  <assets>
  </assets>
  <room use_local_asset="room_plane" fwd="0 0 -1">

    <!-- room environment                                      -->
    <!-- important: use pos to offset the scene,               -->
    <!--            that way the overlay-rooms align correctly -->
    <object pos="0 0 0">   

      <object id="cube" scale="0.5 0.5 0.5" pos="0 0.5 -4" col="1 0 0" js_id="mycube"/>


      <!-- xrfragments webui-app: https://xrfragment.org/#%23! (same principle but via URL spec) -->
      <link url="paragraph.xml#!" pos="0 0.05 -6" rotation="-90 0 0.01" scale="2 2 1" shader_id="defaultportal" url_pos="0 1 2" title="spawn room to portal" title_col="0 0 0"/>
      
      <!-- xrfragments webui-app: partial + target="mycube" ( see https://xrfragment.org/#%23!  ) -->
      <link url="paragraph.xml#!p2" pos="-1 1 -4" scale="0.5 0.5 0.5" shader_id="defaultportal" draw_glow="false" billboard="true" url_pos="0 1 0" target="mycube" url_scale="2 2 2" title="spawn partial to mycube" title_col="0 0 0"/>

      <!-- xrfragments webui-app: partial + target="player" ( see https://xrfragment.org/#%23!  ) -->
      <link url="paragraph.xml#!p2" pos="1 1 -4" scale="0.5 0.5 0.5" shader_id="defaultportal" draw_glow="false" billboard="true" url_pos="0 0 -2" target="player" url_scale="2 2 2" title="spawn partial to player" title_col="0 0 0"/>
      
      <!-- xrfragments webui-app: partial to object ( see https://xrfragment.org/#%23!  ) -->
      <link url="paragraph.xml#!p2=mycube" pos="-1 2 -4" scale="0.5 0.5 0.5" shader_id="defaultportal" draw_glow="false" billboard="true" url_pos="0 1 0" url_scale="2 2 2" title="paragraph.xml#!p2=mycube" title_col="0 0 0"/>

      <!-- xrfragments webui-app: partials to objects (see https://xrfragment.org/#%23! ) -->
      <link url="paragraph.xml#!p2=mycube&!p1=player" pos="1 2 -4" scale="0.5 0.5 0.5" shader_id="defaultportal" draw_glow="false" billboard="true" url_pos="0 1 0" url_scale="2 2 2" title="paragraph.xml#!p2=mycube&!p1=player" title_col="0 0 0"/>

      <!-- external portal (just to test back-button) -->
      <link url="https://janusxr.org" pos="-15 0 -6" scale="2 3 1" shader_id="defaultportal" billboard="true" draw_glow="false"/>
    </object>
    
  </room>
</fireboxroom>
